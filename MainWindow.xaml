<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Cleaner.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Cleaner"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
              Padding="16,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="Assets/app.png" Width="32" Height="32" Margin="0,0,12,0"/>
                <TextBlock Text="{StaticResource AppTitle}" 
                           FontSize="20" FontWeight="SemiBold" 
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button x:Name="SelectAllButton" 
                        Content="{StaticResource SelectAllButton}" 
                        Click="SelectAll_Click" 
                        Style="{StaticResource AnimatedAccentButtonStyle}"
                        PointerPressed="Button_PointerPressed"
                        PointerReleased="Button_PointerReleased"/>
                <Button x:Name="DeselectAllButton" 
                        Content="{StaticResource DeselectAllButton}" 
                        Click="DeselectAll_Click"
                        Style="{StaticResource AnimatedButtonStyle}"
                        PointerPressed="Button_PointerPressed"
                        PointerReleased="Button_PointerReleased"/>
                <Button x:Name="CalculateButton" 
                        Content="{StaticResource CalculateButton}" 
                        Click="Calculate_Click" 
                        Style="{StaticResource AnimatedAccentButtonStyle}"
                        PointerPressed="Button_PointerPressed"
                        PointerReleased="Button_PointerReleased"/>
            </StackPanel>
        </Grid>

        <!-- Success InfoBar -->
        <InfoBar x:Name="SuccessInfoBar" 
                 Grid.Row="1"
                 Severity="Success"
                 Title="Cleaning Completed"
                 Message="All selected items have been cleaned successfully!"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="16,8,16,0"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <StackPanel Spacing="16">
                
                <!-- Basic Cleaning -->
                <Expander Header="{StaticResource CategoryBasic}" IsExpanded="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="8" Margin="0,8,0,0">
                        <CheckBox x:Name="WindowsTempCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource WindowsTemp}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource WindowsTempDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="WindowsTempSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="UserTempCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource UserTemp}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource UserTempDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="UserTempSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="RecycleBinCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource RecycleBin}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource RecycleBinDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="RecycleBinSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="BrowserCacheCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource BrowserCache}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource BrowserCacheDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="BrowserCacheSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="WindowsUpdateCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource WindowsUpdate}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource WindowsUpdateDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="WindowsUpdateSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    </StackPanel>
                </Expander>

                <!-- NVIDIA & DirectX -->
                <Expander Header="{StaticResource CategoryNvidia}" IsExpanded="True"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="8" Margin="0,8,0,0">
                        <CheckBox x:Name="NvidiaCacheCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource NvidiaCache}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource NvidiaCacheDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="NvidiaCacheSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="NvidiaInstallersCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource NvidiaInstallers}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource NvidiaInstallersDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="NvidiaInstallersSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="AmdCacheCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource AmdCache}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource AmdCacheDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="AmdCacheSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="DirectXCacheCheck" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="{StaticResource DirectXCache}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource DirectXCacheDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="DirectXCacheSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    </StackPanel>
                </Expander>

                <!-- System Files -->
                <Expander Header="{StaticResource CategorySystem}" IsExpanded="False"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="8" Margin="0,8,0,0">
                        <CheckBox x:Name="PrefetchCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource Prefetch}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource PrefetchDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="PrefetchSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="WindowsStoreCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource WindowsStore}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource WindowsStoreDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="WindowsStoreSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="DeliveryOptimizationCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource DeliveryOptimization}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource DeliveryOptimizationDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="DeliveryOptimizationSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="EventLogsCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource EventLogs}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource EventLogsDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="EventLogsSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="NetworkUsageCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource NetworkUsage}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource NetworkUsageDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="NetworkUsageSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="RegistryHistoryCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource RegistryHistory}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource RegistryHistoryDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="RegistryHistorySize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    </StackPanel>
                </Expander>

                <!-- History -->
                <Expander Header="{StaticResource CategoryHistory}" IsExpanded="False"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                    <StackPanel Spacing="8" Margin="0,8,0,0">
                        <CheckBox x:Name="RecentFilesCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource RecentFiles}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource RecentFilesDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="RecentFilesSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                        <CheckBox x:Name="JumpListsCheck" IsChecked="False">
                            <StackPanel>
                                <TextBlock Text="{StaticResource JumpLists}" FontWeight="SemiBold"/>
                                <TextBlock Text="{StaticResource JumpListsDesc}" 
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                           FontSize="12"/>
                            </StackPanel>
                        </CheckBox>
                        <TextBlock x:Name="JumpListsSize" Text="..." Margin="32,0,0,0" 
                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    </StackPanel>
                </Expander>

                <!-- Log -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock Text="{StaticResource LogTitle}" FontWeight="SemiBold" FontSize="16"/>
                            <Button Content="{StaticResource ClearLog}" 
                                    HorizontalAlignment="Right" 
                                    Click="ClearLog_Click"
                                    Style="{StaticResource AnimatedButtonStyle}"
                                    PointerPressed="Button_PointerPressed"
                                    PointerReleased="Button_PointerReleased"/>
                        </Grid>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="LogTextBlock" TextWrapping="Wrap" 
                                       FontFamily="Consolas" FontSize="12"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
              Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{StaticResource TotalSize}" FontWeight="SemiBold"/>
                <TextBlock x:Name="TotalSizeText" Text="0 MB" 
                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" 
                           FontWeight="Bold" FontSize="16"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ProgressRing x:Name="CleaningProgress" IsActive="False" Width="32" Height="32"/>
                <Button x:Name="CleanButton" Content="{StaticResource CleanButton}" 
                        Click="Clean_Click" 
                        Style="{StaticResource AnimatedAccentButtonStyle}" 
                        MinWidth="120"
                        PointerPressed="Button_PointerPressed"
                        PointerReleased="Button_PointerReleased"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
